# ─────────────────────────────────────────────────────────────
# Fichier .env pour le VPS — À COPIER dans le dossier du projet
# NE JAMAIS COMMITER ce fichier (il est dans .gitignore)
# ─────────────────────────────────────────────────────────────

# PostgreSQL (adapter selon votre config VPS)
DATABASE_URL=postgresql://postgres:MOT_DE_PASSE_FORT@db:5432/sentinelia

# Clés Sightengine (depuis https://sightengine.com/dashboard)
SIGHTENGINE_API_USER=votre_api_user
SIGHTENGINE_API_SECRET=votre_api_secret

# URL du frontend Vercel (à renseigner après déploiement)
FRONTEND_URL=https://sentinelia.vercel.app
